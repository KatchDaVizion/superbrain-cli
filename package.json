    "dev:mcp": "bun ./src/mcp/server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.14.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  }
}
