{
  "name": "superbrain-cli",
  "version": "3.0.0",
  "description": "SuperBrain Protocol CLI — SN442 Decentralized Knowledge Network",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "sb": "./sb"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./sb --target bun",
